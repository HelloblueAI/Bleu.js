# Exclude JavaScript-related files
*.js linguist-vendored
*.jsx linguist-vendored
*.ts linguist-vendored
*.tsx linguist-vendored
*.vue linguist-vendored
frontend/* linguist-vendored
public/* linguist-vendored

# Exclude non-Python assets
*.html linguist-vendored
*.css linguist-vendored
*.svg linguist-vendored
*.json linguist-vendored
*.map linguist-vendored
*.md linguist-vendored

# Vendored directories
node_modules/* linguist-vendored
dist/* linguist-vendored
tests/* linguist-vendored

# Highlight Python
*.py linguist-language=Python
