# Mark JavaScript and other non-Python files as vendored
node_modules/* linguist-vendored
dist/* linguist-vendored
*.js linguist-vendored
*.jsx linguist-vendored
*.ts linguist-vendored
*.tsx linguist-vendored
*.vue linguist-vendored
*.html linguist-vendored
*.css linguist-vendored
*.json linguist-vendored
*.md linguist-vendored
*.svg linguist-vendored
*.yaml linguist-vendored
*.yml linguist-vendored
*.map linguist-vendored

# Mark large files for Git LFS
*.tgz filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar filter=lfs diff=lfs merge=lfs -text
*.gz filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text

# Ensure Python is highlighted
*.py linguist-language=Python

# Mark Python-related environments and caches as vendored
venv/* linguist-vendored
env/* linguist-vendored
__pycache__/* linguist-vendored

# Other generated or unnecessary files
*.lock linguist-vendored
*.iml linguist-vendored
*.class linguist-vendored
*.log linguist-vendored
*.out linguist-vendored
*.bak linguist-vendored
